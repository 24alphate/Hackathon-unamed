# Copy to `.env` (gitignored). Vite loads `API_PROXY` via loadEnv in vite.config.js.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Node API (server/index.js) default: 3001. Python FastAPI (backend) default: 8000
API_PORT=3001
# Bind address for Node API (default 127.0.0.1). Use 0.0.0.0 only if you need LAN access.
# API_HOST=127.0.0.1

# Vite dev/preview: where to proxy /api (default http://127.0.0.1:3001 — must match API_PORT)
API_PROXY=http://127.0.0.1:3001

# VITE (frontend build): full API origin *without* trailing /api, e.g. http://127.0.0.1:3001
# Leave unset in local dev: the app uses same-origin /api and Vite proxies to Node (no CORS issues).
# VITE_API_BASE_URL=http://127.0.0.1:3001

# Optional: default is server/data/unmapped.db (Node) or backend/data/unmapped.db (Python)
# SQLITE_PATH=
# Optional (Python semantic matching): sentence-transformers model and Chroma persistence path
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CHROMA_PATH=backend/data/chroma

# Optional: higher rate limits and access to more repos (classic PAT or fine-grained)
GITHUB_TOKEN=

# Optional: set to 1 to enable Playwright-based live demo runtime verification in the backend.
# Requires Playwright browsers installed: npx playwright install chromium
ENABLE_PLAYWRIGHT_VERIFY=1

# Optional: Stripe/Paystack/etc. link opened when employer clicks "Generate Payment Link" in the demo UI
# VITE_DEMO_PAYMENT_URL=
